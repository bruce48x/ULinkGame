# Alicloud provider credentials are read from environment variables:
#   ALICLOUD_ACCESS_KEY
#   ALICLOUD_SECRET_KEY
#   ALICLOUD_REGION

image_id          = "replace-with-debian-or-ubuntu-image-id"
ssh_allowed_cidr  = "replace-with-your-public-ip/32"
key_pair_name     = "replace-with-existing-key-pair"
silo_count        = 2
edge_count        = 2
data_instance_type = "ecs.c8a.large"
silo_instance_type = "ecs.c8a.large"
edge_instance_type = "ecs.c8a.large"

# Build and push these from the repository root:
#   docker build -f samples/Agar.Unity/Server/Dockerfile --target edge -t registry.example.com/ulinkgame/agar-edge:small-test .
#   docker build -f samples/Agar.Unity/Server/Dockerfile --target silo -t registry.example.com/ulinkgame/agar-silo:small-test .
edge_image = "registry.example.com/ulinkgame/agar-edge:small-test"
silo_image = "registry.example.com/ulinkgame/agar-silo:small-test"

postgres_password = "replace-with-strong-postgres-password"
redis_password    = "replace-with-strong-redis-password"
